@page
@model GroupAssignmentStudentRegistration.Pages.ContactUsModel
@{
}
<div class="flex flex-col items-center space-y-8 mt-8 min-h-screen">
    <h2 class="text-white text-2xl font-bold">Contact Us</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 w-full px-8">

        <!-- Email Card -->
        <div class="bg-[#1F1F1F] text-white p-6 rounded-2xl shadow-md h-full">
            <h3 class="text-xl font-bold mb-2 text-center">Email</h3>
            <p class="text-center text-gray-300">
                General Inquiries: <br />
                <a href="mailto:support@edusphere.edu" class="text-fuchsia-400 hover:underline">support@edusphere.edu</a><br />
                Admissions: <br />
                <a href="mailto:admissions@edusphere.edu" class="text-fuchsia-400 hover:underline">admissions@edusphere.edu</a>
            </p>
        </div>

        <!-- Phone Card -->
        <div class="bg-[#1F1F1F] text-white p-6 rounded-2xl shadow-md h-full">
            <h3 class="text-xl font-bold mb-2 text-center">Phone</h3>
            <p class="text-center text-gray-300">
                General Line: <br />
                <span class="text-fuchsia-400">+1 (800) 123-4567</span><br /><br />
                Student Services: <br />
                <span class="text-fuchsia-400">+1 (800) 765-4321</span>
            </p>
        </div>

        <!-- Social Media Card -->
        <div class="bg-[#1F1F1F] text-white p-6 rounded-2xl shadow-md h-full">
            <h3 class="text-xl font-bold mb-2 text-center">Social Media</h3>
            <ul class="text-center text-gray-300 space-y-2">
                <li><a href="#" class="text-fuchsia-400 hover:underline">Facebook</a></li>
                <li><a href="#" class="text-fuchsia-400 hover:underline">Instagraml</a></li>
                <li><a href="#" class="text-fuchsia-400 hover:underline">Twitter</a></li>
                <li><a href="#" class="text-fuchsia-400 hover:underline">LinkedIn</a></li>
            </ul>
        </div>

    </div>
</div>

